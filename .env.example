# ─── Proxmox Connection ───────────────────────────────────────────────────────
# Full URL to your Proxmox host (include port 8006)
PROXMOX_HOST=https://192.168.1.100:8006

# Set to false if using Proxmox's default self-signed certificate (recommended for home labs)
PROXMOX_TLS_VERIFY=false

# ─── Session Security ─────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-character-secret-string-here

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT=3001

# Origins allowed to make requests to the API (comma separated in production)
CORS_ORIGIN=http://localhost:5173

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
