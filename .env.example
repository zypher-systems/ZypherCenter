# ── ZypherCenter — Environment Variables ──────────────────────────────────────
# For deployment:   copy to .env, fill in PROXMOX_HOST and SESSION_SECRET
# For development:  copy to .env, adjust CORS_ORIGIN to match your dev port
# ─────────────────────────────────────────────────────────────────────────────

# ─── Proxmox Connection ───────────────────────────────────────────────────────
# Full URL to your Proxmox host (include port 8006).
# If omitted, users enter the host URL on the login page.
PROXMOX_HOST=https://192.168.1.100:8006

# Set to "false" to accept self-signed certificates (common in home labs).
PROXMOX_TLS_VERIFY=false

# ─── Session Security ─────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
# If omitted, a random secret is used (sessions reset on container restart).
SESSION_SECRET=

# Set to "true" only if serving ZypherCenter over HTTPS.
COOKIE_SECURE=false

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT=3001

# Origin(s) allowed to call the API directly.
# In Docker deployment the nginx proxy handles this — set to the URL users access.
CORS_ORIGIN=http://localhost:5173

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development

# ─── Deployment Image (docker-compose.yml) ────────────────────────────────────
# These only apply when using docker-compose.yml (deployment mode).
# HTTP_PORT=80
# IMAGE_REGISTRY=zyphersystems
# IMAGE_TAG=latest
