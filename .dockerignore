# ── Git internals ─────────────────────────────────────────────────────────────
.git
.gitignore

# ── Dependencies (reinstalled inside Docker) ──────────────────────────────────
**/node_modules

# ── Build outputs (rebuilt inside Docker) ─────────────────────────────────────
**/dist
**/build
**/.output

# ── Secrets / local env ───────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── TypeScript incremental info ───────────────────────────────────────────────
*.tsbuildinfo

# ── Tailwind cache ────────────────────────────────────────────────────────────
.tailwindcache/

# ── pnpm store ────────────────────────────────────────────────────────────────
.pnpm-store/

# ── Docs (not needed inside the image) ────────────────────────────────────────
README.md
